<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="DefaultControl" TargetType="Control">
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="9pt" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="MinWidth" Value="150" />
        <Setter Property="MinHeight" Value="22" />
        <Setter Property="Margin" Value="5" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style TargetType="Label" BasedOn="{StaticResource DefaultControl}" />

    <Style TargetType="TextBox" BasedOn="{StaticResource DefaultControl}" >
        <Style.Triggers>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsReadOnly" Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="#E9E9E9" />
            </MultiTrigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ComboBox" BasedOn="{StaticResource DefaultControl}" />

    <Style TargetType="Button" BasedOn="{StaticResource DefaultControl}" >
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="5" />
        <Setter Property="MinWidth" Value="75" />
    </Style>

    <Style x:Key="MainGrid" TargetType="Grid">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Margin" Value="10" />
    </Style>

    <Style TargetType="ListBox" BasedOn="{StaticResource DefaultControl}" />

    <Style TargetType="RowDefinition">
        <Setter Property="Height" Value="Auto" />
    </Style>

</ResourceDictionary>